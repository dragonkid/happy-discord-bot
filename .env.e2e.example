# E2E Smoke Test Configuration
# Copy to .env.e2e and fill in values

# Test bot token (second Discord bot for sending test messages)
E2E_DISCORD_TOKEN=

# Dedicated test channel ID (both bots must have access)
E2E_DISCORD_CHANNEL_ID=

# Main bot's Discord token (used to start bot subprocess)
E2E_BOT_DISCORD_TOKEN=

# Optional: machine ID for session spawn (auto-detected if omitted)
# E2E_MACHINE_ID=
